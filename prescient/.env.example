# Required
DUNE_API_KEY=your_dune_api_key_here
UNISWAP_API_KEY=your_uniswap_api_key_here

# Optional API keys
TWITTER_BEARER_TOKEN=
FARCASTER_API_KEY=
LIGHTHOUSE_API_KEY=

# Chain config
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453
AGENT_PRIVATE_KEY=

# Dune query IDs (create on Dune dashboard, paste IDs here)
DUNE_QUERY_TVL=0
DUNE_QUERY_WHALE=0
DUNE_QUERY_GOVERNANCE=0
DUNE_QUERY_LAUNCHES=0

# Agent tuning
DISCOVERY_INTERVAL=3600
MIN_TRADABILITY_SCORE=0.5
CACHE_TTL=300

# Auth
JWT_SECRET=generate-a-strong-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
